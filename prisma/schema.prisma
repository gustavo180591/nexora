generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role      @default(BUYER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions  Session[]   // 👈 ESTO FALTABA
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

enum Role {
  ADMIN
  SELLER
  BUYER
}